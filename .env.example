# ============================================
# FERRULE — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# --- Stellar Testnet Wallets ---
# Create keypairs at: https://lab.stellar.org/account/create
# Fund with XLM at: https://lab.stellar.org/account/fund
# Get USDC at: https://faucet.circle.com (select Stellar Testnet)

# Orchestrator wallet (funds channels, pays agents)
ORCHESTRATOR_SECRET=S...
ORCHESTRATOR_PUBLIC=G...

# LLM Agent wallet (receives MPP Session payments)
LLM_AGENT_SECRET=S...
LLM_AGENT_PUBLIC=G...

# Search Agent wallet (receives x402 payments)
SEARCH_AGENT_SECRET=S...
SEARCH_AGENT_PUBLIC=G...

# Risk Agent wallet (sends x402 payments)
RISK_AGENT_SECRET=S...
RISK_AGENT_PUBLIC=G...

# --- MPP Session Channel ---
# Deploy the one-way-channel contract first, then paste the contract ID here
CHANNEL_CONTRACT=C...

# Ed25519 commitment keypair (hex) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COMMITMENT_SECRET=<64-hex-chars>
COMMITMENT_PUBKEY=<64-hex-chars>

# Shared secret for MPP credential verification (any strong random string)
MPP_SECRET_KEY=replace-with-a-strong-random-secret

# --- LLM ---
# Get your API key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# --- Server ---
PORT=3000
FRONTEND_URL=http://localhost:3001

# --- Network ---
STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
